# ── Egonetics Backend ─────────────────────────────────────────
EGONETICS_URL=http://localhost:3002
EGONETICS_TOKEN=your_agent_jwt_token_here

# ── LLM Provider ──────────────────────────────────────────────
# Default: Anthropic SDK (supports custom base_url for compatible endpoints)
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-6

ANTHROPIC_API_KEY=your_anthropic_or_compatible_api_key
ANTHROPIC_BASE_URL=   # leave empty for official; e.g. https://ark.cn-beijing.volces.com/api/coding

# OpenAI-compatible fallback
OPENAI_API_KEY=

# ── Local model inference ─────────────────────────────────────
# Path to local Qwen / Llama weights for edge inference
MODEL_PATH=/path/to/model_weights
INFERENCE_PORT=8001

# ── Network ───────────────────────────────────────────────────
# If you need an HTTP proxy (port changes per session — set at runtime):
# export HTTP_PROXY=http://127.0.0.1:<port>
# export HTTPS_PROXY=http://127.0.0.1:<port>
